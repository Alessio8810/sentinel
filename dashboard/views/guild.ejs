        canale</button>
      <div id="instagramStatus" style="margin-top:12px;font-size:0.85rem;display:none;"></div>
    </div>

    <!-- ── PROGRAMMAZIONE LIVE ── -->
    <div class="card" id="liveschedule">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(88,101,242,.12);color:#5865F2;"><i class="fa-solid fa-calendar-days"></i></div>
        <div class="card-header-text">
          <h3>Programmazione Live</h3>
          <p>Orari settimanali delle live — gli iscritti ricevono un DM 30 min prima</p>
        </div>
      </div>

      <!-- Canale annunci -->
      <div class="form-group">
        <label class="form-label">Canale annunci live <span style="color:var(--muted);font-weight:400;">(opzionale)</span></label>
        <select class="form-input" id="scheduleChannel">
          <option value="">— Nessuno —</option>
          <% channels.filter(c => c.type === 0 || c.type === 5).forEach(c => { %>
            <option value="<%= c.id %>" <%= config.scheduleChannel === c.id ? 'selected' : '' %>># <%= c.name %></option>
          <% }) %>
        </select>
        <div class="form-hint">Se impostato, il bot manda <code>@here</code> in questo canale 30 min prima di ogni live</div>
      </div>
      <button class="btn btn-accent" style="margin-bottom:24px;" onclick="saveScheduleChannel()"><i class="fa-solid fa-floppy-disk"></i> Salva canale</button>
      <div id="scheduleChannelStatus" style="margin-bottom:16px;font-size:0.85rem;display:none;"></div>

      <!-- Programmazione corrente -->
      <div style="border-top:1px solid var(--border);padding-top:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
          <div style="font-size:0.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);">Programmazione settimanale</div>
          <span style="font-size:0.78rem;color:var(--muted);"><%= (config.scheduleSubscribers||[]).length %> iscritti alle notifiche</span>
        </div>

        <% const liveSchedule = config.liveSchedule || [];
           const dayNames = ['Dom','Lun','Mar','Mer','Gio','Ven','Sab'];
           const platformEmojis = { twitch:'🟣', youtube:'▶️', tiktok:'🎵', instagram:'📸', altro:'🎮' };
        %>
        <% if (liveSchedule.length === 0) { %>
          <div class="list-empty">
            <i class="fa-solid fa-calendar-days"></i>
            <p>Nessuna live in programma.<br>Usa <code>/schedule add</code> su Discord per aggiungerne una.</p>
          </div>
        <% } else { %>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px;">
            <% liveSchedule.slice().sort((a,b) => a.giorno - b.giorno || a.orario.localeCompare(b.orario)).forEach(e => { %>
              <div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;display:flex;flex-direction:column;gap:6px;">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                  <span style="font-size:0.8rem;font-weight:700;color:var(--muted);">📆 <%= dayNames[e.giorno] %> · <%= e.orario %></span>
                  <span style="font-size:1rem;"><%= platformEmojis[e.piattaforma] || '🎮' %></span>
                </div>
                <div style="font-weight:700;font-size:0.95rem;"><%= e.titolo %></div>
                <% if (e.note) { %><div style="font-size:0.78rem;color:var(--muted);"><%= e.note %></div><% } %>
                <div style="margin-top:4px;display:flex;align-items:center;justify-content:space-between;">
                  <code style="font-size:0.72rem;color:var(--muted);">ID: <%= e.id %></code>
                  <button class="btn btn-sm" style="background:rgba(248,81,73,.12);color:var(--red);padding:4px 10px;" onclick="removeLive(<%= e.id %>)">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

        <div class="info-box" style="margin-top:16px;">
          <i class="fa-solid fa-circle-info" style="margin-right:6px;color:var(--accent);"></i>
          Gestisci la programmazione con: <code>/schedule add</code> · <code>/schedule list</code> · <code>/schedule remove</code><br>
          Gli utenti possono iscriversi con <code>/schedule-notify subscribe</code>
        </div>
      </div>
    </div>

    <!-- ── COMANDI CUSTOM ── -->
    <div class="card" id="customcmds">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(52,211,153,.12);color:#34d399;"><i
            class="fa-solid fa-terminal"></i></div>
        <div class="card-header-text">
          <h3>Comandi Personalizzati</h3>
          <p>Comandi slash creati da te con risposte personalizzate</p>
        </div>
      </div>
      <% const cc=config.customCommands || []; %>
        <% if (cc.length===0) { %>
          <div class="list-empty">
            <i class="fa-solid fa-terminal"></i>
            <p>Nessun comando personalizzato.<br>Usa <code>/customcommand add</code> su Discord per crearne uno.</p>
          </div>
          <% } else { %>
            <% cc.forEach((cmd)=> { %>
              <div class="list-item">
                <div>
                  <div class="list-item-main">/<%= cmd.name %>
                  </div>
                  <div class="list-item-sub"
                    style="max-width:500px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    <%= cmd.response %>
                  </div>
                </div>
                <span class="badge badge-green">Attivo</span>
              </div>
              <% }); %>
                <% } %>
                  <div class="info-box" style="margin-top:16px;">
                    <i class="fa-solid fa-circle-info" style="margin-right:6px;color:var(--accent);"></i>
                    Gestisci i comandi con: <code>/customcommand add</code> · <code>/customcommand remove</code> ·
                    <code>/customcommand list</code>
                  </div>
    </div>

  </main>

  <!-- TOAST -->
  <div id="toast"></div>

  <script>
    // ─── TOAST ───
    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      t.className = `show ${type}`;
      t.innerHTML = `<i class="fa-solid fa-${type === 'success' ? 'check' : 'xmark'}"></i> ${msg}`;
      clearTimeout(t._timer);
      t._timer = setTimeout(() => { t.className = ''; }, 3000);
    }

    // ─── SIDEBAR ACTIVE ───
    const sections = ['general', 'welcome', 'levels', 'moderation', 'automod', 'music', 'tickets', 'reactionroles', 'botpersonalization', 'twitch', 'tiktok', 'instagram', 'customcmds'];
    window.addEventListener('scroll', () => {
      let current = sections[0];
      for (const id of sections) {
        const el = document.getElementById(id);
        if (el && el.getBoundingClientRect().top <= 100) current = id;
      }
      document.querySelectorAll('.nav-link').forEach(l => {
        l.classList.toggle('active', l.getAttribute('href') === `#${current}`);
      });
    });

    // ─── AVATAR PREVIEW ───
    document.getElementById('botAvatarUrl').addEventListener('input', function () {
      const preview = document.getElementById('avatarPreview');
      if (this.value.startsWith('http')) {
        preview.src = this.value;
        preview.style.display = 'block';
        preview.onerror = () => { preview.style.display = 'none'; };
      } else {
        preview.style.display = 'none';
      }
    });

    // ─── PERSONALIZZAZIONE ───
    async function savePersonalization() {
      const nick = document.getElementById('botNick').value;
      const avatarUrl = document.getElementById('botAvatarUrl').value;
      const activityType = document.getElementById('botActivityType').value;
      const activityText = document.getElementById('botActivityText').value;
      const status = document.getElementById('personalizationStatus');

      status.style.display = 'block';
      status.style.color = 'var(--muted)';
      status.textContent = '⏳ Applicazione in corso...';

      try {
        const res = await fetch('/dashboard/<%= guild.id %>/personalize', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nick, avatarUrl, activityType, activityText }),
        });
        const json = await res.json();
        if (json.success) {
          status.style.color = 'var(--green)';
          status.textContent = '✅ ' + (json.message || 'Applicato!');
        } else {
          status.style.color = 'var(--red)';
          status.textContent = '❌ ' + (json.error || 'Errore.');
        }
      } catch {
        status.style.color = 'var(--red)';
        status.textContent = '❌ Errore di rete.';
      }
    }

    // ─── TIKTOK SEARCH / SUBSCRIBE ───
    const GUILD_ID = '<%= guild.id %>';
    let tiktokFoundUser = null;

    function formatFollowers(n) {
      if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
      if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
      return String(n);
    }

    async function searchTikTok() {
      const username = document.getElementById('tiktokSearchInput').value.replace('@', '').trim();
      if (!username) return;

      const btn = document.getElementById('tiktokSearchBtn');
      const card = document.getElementById('tiktokProfileCard');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
      card.style.display = 'none';
      tiktokFoundUser = null;

      try {
        const resp = await fetch(`/api/${GUILD_ID}/tiktok/search?username=${encodeURIComponent(username)}`);
        const data = await resp.json();

        if (resp.ok && data.username) {
          document.getElementById('tiktokProfileAvatar').src = data.avatar || '';
          document.getElementById('tiktokProfileName').textContent = data.nickname || ('@' + username);
          document.getElementById('tiktokProfileHandle').textContent = '@' + data.username;
          document.getElementById('tiktokProfileStats').textContent = data.followers ? formatFollowers(data.followers) + ' follower' : '';
          tiktokFoundUser = data;
        } else {
          // Profilo non recuperabile ma username valido — mostra card minimale
          document.getElementById('tiktokProfileAvatar').src = '';
          document.getElementById('tiktokProfileName').textContent = '@' + username;
          document.getElementById('tiktokProfileHandle').textContent = '';
          document.getElementById('tiktokProfileStats').textContent = 'Anteprima non disponibile';
          tiktokFoundUser = { username };
        }
        card.style.display = 'block';
      } catch (e) {
        showToast('Errore di rete durante la ricerca', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-magnifying-glass"></i> Cerca';
      }
    }

    async function subscribeTikTok() {
      if (!tiktokFoundUser) return;
      const username = tiktokFoundUser.username;

      const btn = document.getElementById('tiktokSubscribeBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

      try {
        const resp = await fetch(`/api/${GUILD_ID}/tiktok/subscribe`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username }),
        });
        const data = await resp.json();

        if (data.success) {
          const list = document.getElementById('tiktokUserList');
          const empty = document.getElementById('tiktokEmptyState');
          if (empty) empty.remove();

          if (!document.getElementById(`tiktok-row-${username}`)) {
            const row = document.createElement('div');
            row.className = 'list-item';
            row.id = `tiktok-row-${username}`;
            row.innerHTML = `
              <div><div class="list-item-main">🎵 @${username}</div></div>
              <button class="btn btn-sm" style="background:rgba(248,81,73,.15);color:var(--red);" onclick="unsubscribeTikTok('${username}')">
                <i class="fa-solid fa-trash"></i>
              </button>`;
            list.appendChild(row);
          }

          document.getElementById('tiktokProfileCard').style.display = 'none';
          document.getElementById('tiktokSearchInput').value = '';
          tiktokFoundUser = null;
          showToast(`@${username} aggiunto!`, 'success');
        } else {
          showToast(data.error || 'Errore durante il subscribe', 'error');
        }
      } catch (e) {
        showToast('Errore di rete', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-plus"></i> Subscribe';
      }
    }

    async function unsubscribeTikTok(username) {
      try {
        const resp = await fetch(`/api/${GUILD_ID}/tiktok/subscribe`, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username }),
        });
        const data = await resp.json();

        if (data.success) {
          const row = document.getElementById(`tiktok-row-${username}`);
          if (row) row.remove();
          const list = document.getElementById('tiktokUserList');
          if (!list.querySelector('.list-item')) {
            list.innerHTML = '<div id="tiktokEmptyState" class="list-empty"><i class="fa-brands fa-tiktok"></i><p>Nessun account monitorato.</p></div>';
          }
          showToast(`@${username} rimosso`, 'success');
        } else {
          showToast(data.error || 'Errore', 'error');
        }
      } catch (e) {
        showToast('Errore di rete', 'error');
      }
    }

    // ─── TIKTOK POSTS SUMMARY ───
    async function loadTikTokPosts() {
      const grid = document.getElementById('tiktokPostsGrid');
      grid.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;padding:12px 0;"><i class="fa-solid fa-spinner fa-spin" style="margin-right:6px;"></i>Caricamento...</div>';
      try {
        const resp = await fetch(`/api/${GUILD_ID}/tiktok/posts`);
        const users = await resp.json();

        if (!Array.isArray(users) || users.length === 0) {
          grid.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;padding:12px 0;">Nessun account monitorato.</div>';
          return;
        }

        const cards = users.map(u => {
          const p = u.lastPost;
          if (!p) {
            return `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px;">
              <div style="font-weight:600;margin-bottom:6px;">🎵 @${u.name}</div>
              <div style="color:var(--muted);font-size:0.82rem;">Nessun post recuperato ancora.<br>Il primo check aggiornerà questo riepilogo.</div>
            </div>`;
          }
          const ts = p.timestamp ? new Date(p.timestamp).toLocaleString('it-IT', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '';
          const desc = p.desc ? (p.desc.length > 80 ? p.desc.slice(0, 77) + '…' : p.desc) : '';
          const likes = p.likes != null ? Number(p.likes).toLocaleString('it') : '—';
          const views = p.views != null ? Number(p.views).toLocaleString('it') : '—';
          const cover = p.cover ? `<a href="${p.url}" target="_blank" rel="noopener"><img src="${p.cover}" style="width:100%;height:140px;object-fit:cover;border-radius:7px;display:block;margin-bottom:10px;" onerror="this.style.display='none'"></a>` : '';
          return `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px;">
            ${cover}
            <div style="font-weight:600;font-size:0.88rem;margin-bottom:4px;">🎵 @${u.name}</div>
            ${desc ? `<div style="color:var(--muted);font-size:0.8rem;margin-bottom:8px;line-height:1.4;">${desc}</div>` : ''}
            <div style="display:flex;gap:12px;font-size:0.78rem;color:var(--muted);margin-bottom:8px;">
              <span>❤️ ${likes}</span>
              <span>▶️ ${views}</span>
              ${ts ? `<span>🕐 ${ts}</span>` : ''}
            </div>
            <a href="${p.url}" target="_blank" rel="noopener" style="font-size:0.78rem;color:var(--accent);text-decoration:none;">
              <i class="fa-solid fa-arrow-up-right-from-square"></i> Apri su TikTok
            </a>
          </div>`;
        });

        grid.innerHTML = cards.join('');
      } catch (e) {
        grid.innerHTML = '<div style="color:var(--red);font-size:0.85rem;">Errore nel caricamento dei post.</div>';
      }
    }

    // Carica al mount della pagina
    loadTikTokPosts();

    // ─── SOCIAL ALERTS ───
    async function saveSocial(platform) {
      const channelEl = document.getElementById(platform + 'Channel');
      const statusEl = document.getElementById(platform + 'Status');
      const channelId = channelEl ? channelEl.value : '';

      statusEl.style.display = 'block';
      statusEl.style.color = 'var(--muted)';
      statusEl.textContent = '⏳ Salvataggio...';

      try {
        const res = await fetch('/dashboard/<%= guild.id %>/save-social', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ platform, channelId }),
        });
        const json = await res.json();
        if (json.success) {
          statusEl.style.color = '#34d399';
          statusEl.textContent = '✅ Canale salvato!';
          showToast('Canale notifiche salvato!', 'success');
        } else {
          statusEl.style.color = '#f87171';
          statusEl.textContent = '❌ ' + (json.error || 'Errore');
        }
      } catch (e) {
        statusEl.style.color = '#f87171';
        statusEl.textContent = '❌ Errore di rete.';
      }
      setTimeout(() => { statusEl.style.display = 'none'; }, 4000);
    }

    async function resetNick() {
      document.getElementById('botNick').value = '';
      await savePersonalization();
    }

    // ─── SCHEDULE LIVE ───
    async function saveScheduleChannel() {
      const channelId = document.getElementById('scheduleChannel').value;
      const statusEl = document.getElementById('scheduleChannelStatus');
      statusEl.style.display = 'block';
      statusEl.style.color = 'var(--muted)';
      statusEl.textContent = '⏳ Salvataggio...';
      try {
        const res = await fetch('/dashboard/<%= guild.id %>/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ section: 'scheduleChannel', data: { scheduleChannel: channelId } }),
        });
        const json = await res.json();
        if (json.success) {
          statusEl.style.color = '#34d399';
          statusEl.textContent = '✅ Canale salvato!';
          showToast('Canale annunci live salvato!', 'success');
        } else {
          statusEl.style.color = '#f87171';
          statusEl.textContent = '❌ ' + (json.error || 'Errore');
        }
      } catch (e) {
        statusEl.style.color = '#f87171';
        statusEl.textContent = '❌ Errore di rete.';
      }
      setTimeout(() => { statusEl.style.display = 'none'; }, 4000);
    }

    async function removeLive(id) {
      if (!confirm('Rimuovere questa live dalla programmazione?')) return;
      try {
        const res = await fetch('/dashboard/<%= guild.id %>/remove-live', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        const json = await res.json();
        if (json.success) {
          showToast('Live rimossa!', 'success');
          setTimeout(() => location.reload(), 800);
        } else {
          showToast(json.error || 'Errore', 'error');
        }
      } catch (e) {
        showToast('Errore di rete.', 'error');
      }
    }

    // ─── TIKTOK SESSION (cookie per-server) ───
    async function saveTikTokSession() {
      const sessionid = document.getElementById('tiktokSessionId').value.trim();
      const ttwid = document.getElementById('tiktokTtwid').value.trim();
      const statusEl = document.getElementById('tiktokSessionStatus');

      // Ignora i placeholder "••••••••"
      if (sessionid === '••••••••••••••••' && ttwid === '••••••••••••••••') {
        showToast('Nessuna modifica ai cookie.', 'info');
        return;
      }

      statusEl.style.display = 'block';
      statusEl.style.color = 'var(--muted)';
      statusEl.textContent = '⏳ Salvataggio...';

      try {
        const res = await fetch('/dashboard/<%= guild.id %>/save-tiktok-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            sessionid: sessionid === '••••••••••••••••' ? null : (sessionid || null),
            ttwid: ttwid === '••••••••••••••••' ? null : (ttwid || null),
          }),
        });
        const json = await res.json();
        if (json.success) {
          statusEl.style.color = '#34d399';
          statusEl.textContent = '✅ Cookie salvati! TikTok userà le tue credenziali per questo server.';
          showToast('Cookie TikTok salvati!', 'success');
        } else {
          statusEl.style.color = '#f87171';
          statusEl.textContent = '❌ ' + (json.error || 'Errore');
        }
      } catch (e) {
        statusEl.style.color = '#f87171';
        statusEl.textContent = '❌ Errore di rete.';
      }
      setTimeout(() => { statusEl.style.display = 'none'; }, 5000);
    }

    async function clearTikTokSession() {
      if (!confirm('Rimuovere i cookie TikTok di questo server? Verrà usato il cookie globale del bot.')) return;
      const statusEl = document.getElementById('tiktokSessionStatus');
      statusEl.style.display = 'block';
      statusEl.style.color = 'var(--muted)';
      statusEl.textContent = '⏳ Rimozione...';
      try {
        const res = await fetch('/dashboard/<%= guild.id %>/save-tiktok-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionid: null, ttwid: null }),
        });
        const json = await res.json();
        if (json.success) {
          statusEl.style.color = '#34d399';
          statusEl.textContent = '✅ Cookie rimossi. Uso cookie globali del bot.';
          document.getElementById('tiktokSessionId').value = '';
          document.getElementById('tiktokTtwid').value = '';
          showToast('Cookie TikTok rimossi.', 'success');
        }
      } catch (e) {
        statusEl.style.color = '#f87171';
        statusEl.textContent = '❌ Errore di rete.';
      }
      setTimeout(() => { statusEl.style.display = 'none'; }, 5000);
    }

    // ─── TAG INPUT (parole bannate) ───
    const badWordInput = document.getElementById('badWordInput');
    badWordInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const word = badWordInput.value.trim().replace(/,/g, '').toLowerCase();
        if (word) addTag(word);
        badWordInput.value = '';
      } else if (e.key === 'Backspace' && !badWordInput.value) {
        const tags = document.querySelectorAll('#badWordsWrap .tag');
        if (tags.length > 0) tags[tags.length - 1].remove();
      }
    });

    function addTag(word) {
      const existing = [...document.querySelectorAll('#badWordsWrap .tag')].map(t => t.dataset.word);
      if (existing.includes(word)) return;
      const wrap = document.getElementById('badWordsWrap');
      const tag = document.createElement('span');
      tag.className = 'tag';
      tag.dataset.word = word;
      tag.innerHTML = `${word}<span class="tag-remove" onclick="removeTag(this)">✕</span>`;
      wrap.insertBefore(tag, badWordInput);
    }

    function removeTag(el) { el.parentElement.remove(); }

    // ─── SAVE ───
    async function save(section) {
      const data = {};

      if (section === 'general') {
        data.prefix = document.getElementById('prefix').value || '!';
      } else if (section === 'welcome') {
        data.welcomeEnabled = document.getElementById('welcomeEnabled').checked;
        data.welcomeChannel = document.getElementById('welcomeChannel').value;
        data.welcomeMessage = document.getElementById('welcomeMessage').value;
      } else if (section === 'levels') {
        data.levelsEnabled = document.getElementById('levelsEnabled').checked;
        data.levelUpChannel = document.getElementById('levelUpChannel').value;
        data.levelUpMessage = document.getElementById('levelUpMessage').value;
      } else if (section === 'moderation') {
        data.modLogChannel = document.getElementById('modLogChannel').value;
      } else if (section === 'automod') {
        const badWords = [...document.querySelectorAll('#badWordsWrap .tag')].map(t => t.dataset.word);
        data.automod = {
          enabled: document.getElementById('am_enabled').checked,
          filterLinks: document.getElementById('am_filterLinks').checked,
          filterInvites: document.getElementById('am_filterInvites').checked,
          filterSpam: document.getElementById('am_filterSpam').checked,
          filterEmojis: document.getElementById('am_filterEmojis').checked,
          spamThreshold: parseInt(document.getElementById('am_spamThreshold').value) || 5,
          spamInterval: (parseInt(document.getElementById('am_spamInterval').value) || 5) * 1000,
          emojiLimit: parseInt(document.getElementById('am_emojiLimit').value) || 10,
          logChannel: document.getElementById('am_logChannel').value || null,
          badWords,
        };
      } else if (section === 'music') {
        data.musicChannel = document.getElementById('musicChannel').value;
        data.djRole = document.getElementById('djRole').value;
      } else if (section === 'tickets') {
        data.ticketsEnabled = document.getElementById('ticketsEnabled').checked;
        data.ticketCategory = document.getElementById('ticketCategory').value;
        data.ticketLogChannel = document.getElementById('ticketLogChannel').value;
      }

      try {
        const res = await fetch('/dashboard/<%= guild.id %>/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ section, data }),
        });
        const json = await res.json();
        if (json.success) showToast('Impostazioni salvate!', 'success');
        else showToast('Errore durante il salvataggio.', 'error');
      } catch {
        showToast('Errore di rete.', 'error');
      }
    }
  </script>
</body>

</html>