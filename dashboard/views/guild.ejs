          <div class="form-hint">Testo mostrato sotto il nome del bot nel profilo Discord</div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Avatar bot (URL immagine, globale)</label>
        <div style="display:flex;gap:12px;align-items:center;">
          <img id="avatarPreview" src="" alt=""
            style="width:56px;height:56px;border-radius:50%;border:2px solid var(--border);object-fit:cover;display:none;">
          <div style="flex:1;">
            <input class="form-input" type="url" id="botAvatarUrl" placeholder="https://esempio.com/avatar.png">
            <div class="form-hint">Incolla un URL diretto a un'immagine PNG o JPG. ⚠️ Discord limita il cambio avatar a
              2 volte/ora.</div>
          </div>
        </div>
      </div>

      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button class="btn btn-accent" onclick="savePersonalization()"><i class="fa-solid fa-floppy-disk"></i>
          Applica</button>
        <button class="btn" style="background:var(--surface2);color:var(--muted);border:1px solid var(--border);"
          onclick="resetNick()"><i class="fa-solid fa-rotate-left"></i> Reset nickname</button>
      </div>
      <div id="personalizationStatus" style="margin-top:12px;font-size:0.85rem;display:none;"></div>
    </div>

    <!-- ── TWITCH ALERTS ── -->
    <div class="card" id="twitch">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(145,70,255,.12);color:#9146ff;"><i
            class="fa-brands fa-twitch"></i></div>
        <div class="card-header-text">
          <h3>Notifiche Live Twitch</h3>
          <p>Ricevi una notifica quando uno streamer inizia una live su Twitch</p>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Canale notifiche</label>
        <select class="form-input" id="twitchChannel">
          <option value="">— Nessuno —</option>
          <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
            <option value="<%= c.id %>" <%=(config.twitchAlerts && config.twitchAlerts.channelId===c.id) ? 'selected'
              : '' %>># <%= c.name %>
            </option>
            <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Streamer monitorati</label>
        <% const twitchStreamers=(config.twitchAlerts && config.twitchAlerts.streamers) || []; %>
          <% if (twitchStreamers.length> 0) { %>
            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
              <% twitchStreamers.forEach(s=> { %>
                <span class="badge" style="background:rgba(145,70,255,.15);color:#9146ff;font-size:0.8rem;">🔴 <%=
                    s.name %>
                    <%= s.lastLive ? '(Live)' : '' %></span>
                <% }) %>
            </div>
            <% } else { %>
              <p style="color:var(--muted);font-size:0.85rem;">Nessuno streamer monitorato. Usa <code>/twitch add</code>
                su Discord.</p>
