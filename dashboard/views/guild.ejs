<!DOCTYPE html>
<html lang="it">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= guild.name %> — Dashboard
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root {
      --bg: #0d1117;
      --surface: #161b22;
      --surface2: #1c2128;
      --border: #30363d;
      --accent: #5865F2;
      --accent-hover: #4752C4;
      --text: #e6edf3;
      --muted: #8b949e;
      --green: #3fb950;
      --red: #f85149;
      --yellow: #e3b341;
      --sidebar-w: 260px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
    }

    /* ─── SIDEBAR ─── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      z-index: 40;
      overflow-y: auto;
    }

    .sidebar-header {
      padding: 20px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .guild-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      object-fit: cover;
    }

    .guild-icon-placeholder {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--accent), #a78bfa);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      font-weight: 700;
    }

    .guild-title {
      font-weight: 700;
      font-size: 0.95rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .guild-sub {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .sidebar-nav {
      flex: 1;
      padding: 12px 0;
    }

    .nav-section-label {
      padding: 12px 16px 6px;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 14px;
      margin: 2px 8px;
      border-radius: 8px;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      transition: all .15s;
    }

    .nav-link:hover {
      background: var(--surface2);
      color: var(--text);
    }

    .nav-link.active {
      background: rgba(88, 101, 242, .15);
      color: var(--accent);
    }

    .nav-link .icon {
      width: 18px;
      text-align: center;
      font-size: 0.9rem;
    }

    .sidebar-footer {
      padding: 12px 8px;
      border-top: 1px solid var(--border);
    }

    .back-link {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 9px 14px;
      border-radius: 8px;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      transition: all .15s;
    }

    .back-link:hover {
      background: var(--surface2);
      color: var(--text);
    }

    /* ─── MAIN ─── */
    .main {
      margin-left: var(--sidebar-w);
      flex: 1;
      padding: 36px 44px;
      max-width: calc(100% - var(--sidebar-w));
    }

    .page-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .page-sub {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 36px;
    }

    /* ─── CARDS ─── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      margin-bottom: 28px;
      scroll-margin-top: 32px;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }

    .card-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }

    .card-header-text h3 {
      font-size: 1.05rem;
      font-weight: 700;
    }

    .card-header-text p {
      color: var(--muted);
      font-size: 0.82rem;
      margin-top: 2px;
    }

    /* ─── FORM ─── */
    .form-group {
      margin-bottom: 20px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .form-label {
      display: block;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 6px;
    }

    .form-hint {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 5px;
    }

    .form-input {
      width: 100%;
      padding: 10px 14px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      transition: border-color .2s, box-shadow .2s;
      outline: none;
    }

    .form-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(88, 101, 242, .2);
    }

    textarea.form-input {
      resize: vertical;
      min-height: 80px;
    }

    /* ─── TOGGLE SWITCH ─── */
    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 16px;
      background: var(--surface2);
      border-radius: 10px;
      margin-bottom: 20px;
    }

    .toggle-row-text .toggle-row-label {
      font-size: 0.9rem;
      font-weight: 500;
      display: block;
    }

    .toggle-row-text .toggle-row-sub {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 2px;
      display: block;
    }

    .switch {
      position: relative;
      display: inline-block;
      width: 44px;
      height: 24px;
      flex-shrink: 0;
    }

    .switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .slider {
      position: absolute;
      inset: 0;
      background: var(--border);
      border-radius: 99px;
      cursor: pointer;
      transition: .2s;
    }

    .slider:before {
      content: '';
      position: absolute;
      width: 18px;
      height: 18px;
      left: 3px;
      top: 3px;
      background: white;
      border-radius: 50%;
      transition: .2s;
    }

    input:checked+.slider {
      background: var(--accent);
    }

    input:checked+.slider:before {
      transform: translateX(20px);
    }

    /* ─── CHECKBOXES GRID (automod) ─── */
    .check-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 20px;
    }

    .check-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 12px;
      background: var(--surface2);
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    .check-item input[type=checkbox] {
      margin-top: 2px;
      accent-color: var(--accent);
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      cursor: pointer;
    }

    .check-item-text .check-label {
      font-size: 0.875rem;
      font-weight: 500;
      display: block;
    }

    .check-item-text .check-sub {
      font-size: 0.77rem;
      color: var(--muted);
      margin-top: 2px;
      display: block;
    }

    /* ─── BADWORDS ─── */
    .tag-input-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 10px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      min-height: 44px;
      cursor: text;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: rgba(88, 101, 242, .2);
      color: var(--accent);
      border-radius: 6px;
      padding: 3px 9px;
      font-size: 0.82rem;
      font-weight: 500;
    }

    .tag-remove {
      cursor: pointer;
      opacity: .7;
      font-size: 0.75rem;
    }

    .tag-remove:hover {
      opacity: 1;
    }

    .tag-ghost {
      border: none;
      outline: none;
      background: transparent;
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      min-width: 80px;
      flex: 1;
    }

    /* ─── LIST VIEW (reaction roles / custom commands) ─── */
    .list-empty {
      text-align: center;
      padding: 32px;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .list-empty i {
      font-size: 2rem;
      opacity: .3;
      margin-bottom: 10px;
      display: block;
    }

    .list-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 14px;
      background: var(--surface2);
      border-radius: 8px;
      margin-bottom: 8px;
      border: 1px solid var(--border);
    }

    .list-item-main {
      font-size: 0.9rem;
      font-weight: 500;
    }

    .list-item-sub {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .badge {
      font-size: 0.72rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 99px;
    }

    .badge-blue {
      background: rgba(88, 101, 242, .2);
      color: var(--accent);
    }

    .badge-green {
      background: rgba(63, 185, 80, .2);
      color: var(--green);
    }

    .info-box {
      background: rgba(88, 101, 242, .08);
      border: 1px solid rgba(88, 101, 242, .25);
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.6;
    }

    .info-box code {
      background: var(--surface2);
      padding: 1px 7px;
      border-radius: 5px;
      color: var(--text);
      font-size: 0.85rem;
    }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 20px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
      border: none;
      cursor: pointer;
      transition: all .2s;
    }

    .btn-accent {
      background: var(--accent);
      color: white;
    }

    .btn-accent:hover {
      background: var(--accent-hover);
    }

    .btn-sm {
      padding: 6px 14px;
      font-size: 0.82rem;
    }

    /* ─── TOAST ─── */
    #toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9999;
      padding: 12px 20px;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 10px;
      transform: translateY(80px);
      opacity: 0;
      transition: all .3s cubic-bezier(.34, 1.56, .64, 1);
      pointer-events: none;
    }

    #toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    #toast.success {
      background: var(--green);
      color: #0d1117;
    }

    #toast.error {
      background: var(--red);
      color: white;
    }

    @media (max-width: 768px) {
      .form-row {
        grid-template-columns: 1fr;
      }

      .check-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <% if (guild.icon) { %>
        <img class="guild-icon" src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="">
        <% } else { %>
          <div class="guild-icon-placeholder">
            <%= guild.name[0] %>
          </div>
          <% } %>
            <div>
              <div class="guild-title">
                <%= guild.name %>
              </div>
              <div class="guild-sub">Configurazione</div>
            </div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section-label">Generale</div>
      <a href="#general" class="nav-link active">
        <span class="icon"><i class="fa-solid fa-gear"></i></span> Impostazioni
      </a>
      <a href="#welcome" class="nav-link">
        <span class="icon"><i class="fa-solid fa-hand-wave"></i></span> Benvenuto
      </a>

      <div class="nav-section-label" style="margin-top:8px;">Livelli</div>
      <a href="#levels" class="nav-link">
        <span class="icon"><i class="fa-solid fa-star"></i></span> Livelli XP
      </a>

      <div class="nav-section-label" style="margin-top:8px;">Moderazione</div>
      <a href="#moderation" class="nav-link">
        <span class="icon"><i class="fa-solid fa-shield-halved"></i></span> Mod Log
      </a>
      <a href="#automod" class="nav-link">
        <span class="icon"><i class="fa-solid fa-robot"></i></span> Auto-Mod
      </a>

      <div class="nav-section-label" style="margin-top:8px;">Funzionalità</div>
      <a href="#music" class="nav-link">
        <span class="icon"><i class="fa-solid fa-music"></i></span> Musica
      </a>
      <a href="#tickets" class="nav-link">
        <span class="icon"><i class="fa-solid fa-ticket"></i></span> Ticket
      </a>
      <a href="#reactionroles" class="nav-link">
        <span class="icon"><i class="fa-solid fa-face-smile"></i></span> Reaction Roles
      </a>
      <a href="#botpersonalization" class="nav-link">
        <span class="icon"><i class="fa-solid fa-palette"></i></span> Personalizzazione
      </a>
      <a href="#twitch" class="nav-link">
        <span class="icon"><i class="fa-brands fa-twitch"></i></span> Twitch
      </a>
      <a href="#tiktok" class="nav-link">
        <span class="icon"><i class="fa-brands fa-tiktok"></i></span> TikTok
      </a>
      <a href="#instagram" class="nav-link">
        <span class="icon"><i class="fa-brands fa-instagram"></i></span> Instagram
      </a>
      <a href="#customcmds" class="nav-link">
        <span class="icon"><i class="fa-solid fa-terminal"></i></span> Comandi Custom
      </a>
    </nav>

    <div class="sidebar-footer">
      <a href="/dashboard" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Tutti i server
      </a>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main">
    <div class="page-title">⚙️ <%= guild.name %>
    </div>
    <div class="page-sub">Configura le funzionalità del bot per questo server</div>

    <!-- ── IMPOSTAZIONI GENERALI ── -->
    <div class="card" id="general">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(139,148,158,.12);color:#8b949e;"><i class="fa-solid fa-gear"></i>
        </div>
        <div class="card-header-text">
          <h3>Impostazioni Generali</h3>
          <p>Configurazione base del bot per questo server</p>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Prefisso comandi</label>
          <input class="form-input" type="text" id="prefix" value="<%= config.prefix || '!' %>" maxlength="5"
            style="max-width:120px;">
          <div class="form-hint">Usato per i comandi testuali legacy (es. <code>!ban</code>)</div>
        </div>
      </div>
      <button class="btn btn-accent" onclick="save('general')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── BENVENUTO ── -->
    <div class="card" id="welcome">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(56,189,248,.12);color:#38bdf8;"><i
            class="fa-solid fa-hand-wave"></i></div>
        <div class="card-header-text">
          <h3>Messaggio di Benvenuto</h3>
          <p>Invia un messaggio quando un nuovo membro si unisce al server</p>
        </div>
      </div>
      <div class="toggle-row">
        <div class="toggle-row-text">
          <span class="toggle-row-label">Abilitato</span>
          <span class="toggle-row-sub">Attiva o disattiva i messaggi di benvenuto</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="welcomeEnabled" <%=config.welcomeEnabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">ID Canale</label>
          <input class="form-input" type="text" id="welcomeChannel" value="<%= config.welcomeChannel || '' %>"
            placeholder="Es. 123456789012345678">
          <div class="form-hint">Copia l'ID tenendo Shift e cliccando sul canale</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Messaggio</label>
        <textarea class="form-input" id="welcomeMessage"
          rows="3"><%= config.welcomeMessage || 'Benvenuto {user} in {server}! Siete ora {memberCount} membri.' %></textarea>
        <div class="form-hint">Variabili: <code>{user}</code> <code>{server}</code> <code>{memberCount}</code></div>
      </div>
      <button class="btn btn-accent" onclick="save('welcome')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── LIVELLI XP ── -->
    <div class="card" id="levels">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(255,184,0,.12);color:#ffb800;"><i class="fa-solid fa-star"></i>
        </div>
        <div class="card-header-text">
          <h3>Sistema Livelli XP</h3>
          <p>Assegna XP ai messaggi e premia i membri più attivi</p>
        </div>
      </div>
      <div class="toggle-row">
        <div class="toggle-row-text">
          <span class="toggle-row-label">Abilitato</span>
          <span class="toggle-row-sub">Attiva o disattiva il sistema XP</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="levelsEnabled" <%=config.levelsEnabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">ID Canale Level-Up</label>
          <input class="form-input" type="text" id="levelUpChannel" value="<%= config.levelUpChannel || '' %>"
            placeholder="Es. 123456789012345678">
          <div class="form-hint">Lascia vuoto per inviare nel canale corrente</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Messaggio Level-Up</label>
        <input class="form-input" type="text" id="levelUpMessage"
          value="<%= config.levelUpMessage || '{user} è salito al livello {level}! 🎉' %>">
        <div class="form-hint">Variabili: <code>{user}</code> <code>{level}</code></div>
      </div>
      <button class="btn btn-accent" onclick="save('levels')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── MOD LOG ── -->
    <div class="card" id="moderation">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(248,81,73,.12);color:#f85149;"><i
            class="fa-solid fa-shield-halved"></i></div>
        <div class="card-header-text">
          <h3>Log Moderazione</h3>
          <p>Registro di tutte le azioni di moderazione (ban, kick, mute, warn)</p>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">ID Canale Mod-Log</label>
          <input class="form-input" type="text" id="modLogChannel" value="<%= config.modLogChannel || '' %>"
            placeholder="Es. 123456789012345678">
          <div class="form-hint">Tutte le azioni di moderazione saranno registrate qui</div>
        </div>
      </div>
      <button class="btn btn-accent" onclick="save('moderation')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── AUTO-MOD ── -->
    <div class="card" id="automod">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(88,101,242,.12);color:#5865F2;"><i class="fa-solid fa-robot"></i>
        </div>
        <div class="card-header-text">
          <h3>Auto-Mod</h3>
          <p>Filtri automatici per mantenere il server pulito</p>
        </div>
      </div>
      <div class="toggle-row">
        <div class="toggle-row-text">
          <span class="toggle-row-label">Auto-Mod Abilitato</span>
          <span class="toggle-row-sub">Attiva o disattiva tutti i filtri automatici</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="am_enabled" <%=(config.automod && config.automod.enabled) ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>

      <div class="check-grid">
        <div class="check-item">
          <input type="checkbox" id="am_filterLinks" <%=(config.automod && config.automod.filterLinks) ? 'checked' : ''
            %>>
          <div class="check-item-text">
            <span class="check-label">Filtro Link</span>
            <span class="check-sub">Elimina messaggi contenenti URL</span>
          </div>
        </div>
        <div class="check-item">
          <input type="checkbox" id="am_filterInvites" <%=(config.automod && config.automod.filterInvites) ? 'checked'
            : '' %>>
          <div class="check-item-text">
            <span class="check-label">Filtro Inviti Discord</span>
            <span class="check-sub">Blocca link discord.gg</span>
          </div>
        </div>
        <div class="check-item">
          <input type="checkbox" id="am_filterSpam" <%=(config.automod && config.automod.filterSpam) ? 'checked' : ''
            %>>
