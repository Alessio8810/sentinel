    <!-- ── INSTAGRAM ALERTS ── -->
    <div class="card" id="instagram">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(225,48,108,.12);color:#e1306c;"><i
            class="fa-brands fa-instagram"></i></div>
        <div class="card-header-text">
          <h3>Notifiche Post Instagram</h3>
          <p>Ricevi una notifica quando un utente pubblica un nuovo post su Instagram</p>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Canale notifiche</label>
        <select class="form-input" id="instagramChannel">
          <option value="">— Nessuno —</option>
          <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
            <option value="<%= c.id %>" <%=(config.instagramAlerts && config.instagramAlerts.channelId===c.id)
              ? 'selected' : '' %>># <%= c.name %>
            </option>
            <% }) %>
