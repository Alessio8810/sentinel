      </div>
      <div class="form-group">
        <label>Account monitorati</label>
        <% const igUsers=(config.instagramAlerts && config.instagramAlerts.users) || []; %>
          <% if (igUsers.length> 0) { %>
            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
              <% igUsers.forEach(u=> { %>
                <span class="badge" style="background:rgba(225,48,108,.15);color:#e1306c;font-size:0.8rem;">📸 @<%=
                    u.name %></span>
                <% }) %>
