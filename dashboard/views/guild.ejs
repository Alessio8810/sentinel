      </div>
      <button class="btn btn-accent" onclick="saveSocial('twitch')"><i class="fa-solid fa-floppy-disk"></i> Salva
        canale</button>
      <div id="twitchStatus" style="margin-top:12px;font-size:0.85rem;display:none;"></div>
    </div>

    <!-- ── TIKTOK ALERTS ── -->
    <div class="card" id="tiktok">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(1,1,1,.2);color:#fff;"><i class="fa-brands fa-tiktok"></i></div>
        <div class="card-header-text">
          <h3>Notifiche Video TikTok</h3>
          <p>Ricevi una notifica quando un utente pubblica un nuovo video su TikTok</p>
        </div>
      </div>

      <!-- Canale notifiche -->
      <div class="form-group">
        <label class="form-label">Canale notifiche</label>
        <select id="tiktokChannel" class="form-input">
          <option value="">— Nessuno —</option>
          <% channels.filter(c=> c.type === 0).forEach(c => { %>
            <option value="<%= c.id %>" <%=(config.tiktokAlerts && config.tiktokAlerts.channelId===c.id) ? 'selected'
              : '' %>>#<%= c.name %>
            </option>
            <% }) %>
        </select>
      </div>

      <!-- Search box -->
      <div class="form-group">
        <label class="form-label">Aggiungi account TikTok</label>
        <div style="display:flex;gap:8px;">
          <input type="text" id="tiktokSearchInput" class="form-input" placeholder="Username TikTok (senza @)"
            style="flex:1;" onkeydown="if(event.key==='Enter')searchTikTok()">
          <button class="btn btn-accent" id="tiktokSearchBtn" onclick="searchTikTok()"><i
              class="fa-solid fa-magnifying-glass"></i> Cerca</button>
        </div>
      </div>

      <!-- Profile card (nascosta di default) -->
      <div id="tiktokProfileCard"
        style="display:none;margin-bottom:20px;padding:16px;background:var(--surface2);border-radius:12px;border:1px solid var(--border);">
        <div style="display:flex;align-items:center;gap:14px;">
          <img id="tiktokProfileAvatar" src="" alt=""
            style="width:52px;height:52px;border-radius:50%;object-fit:cover;background:var(--border);">
          <div style="flex:1;min-width:0;">
            <div id="tiktokProfileName"
              style="font-weight:700;font-size:1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
            <div id="tiktokProfileHandle" style="color:var(--muted);font-size:0.82rem;"></div>
            <div id="tiktokProfileStats" style="color:var(--muted);font-size:0.8rem;margin-top:2px;"></div>
          </div>
          <button class="btn btn-accent btn-sm" onclick="subscribeTikTok()" id="tiktokSubscribeBtn">
            <i class="fa-solid fa-plus"></i> Subscribe
          </button>
        </div>
      </div>

      <!-- Lista account monitorati -->
      <div class="form-group">
        <label class="form-label">Account monitorati</label>
        <div id="tiktokUserList">
          <% const tiktokUsers=(config.tiktokAlerts && config.tiktokAlerts.users) || []; %>
            <% if (tiktokUsers.length> 0) { %>
              <% tiktokUsers.forEach(u=> { %>
                <div class="list-item" id="tiktok-row-<%= u.name %>">
                  <div>
                    <div class="list-item-main">🎵 @<%= u.name %>
                    </div>
                  </div>
                  <button class="btn btn-sm" style="background:rgba(248,81,73,.15);color:var(--red);"
                    onclick="unsubscribeTikTok('<%= u.name %>')">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
                <% }) %>
                  <% } else { %>
                    <div id="tiktokEmptyState" class="list-empty">
                      <i class="fa-brands fa-tiktok"></i>
                      <p>Nessun account monitorato. Cerca un username sopra per aggiungerne uno.</p>
                    </div>
                    <% } %>
        </div>
      </div>

      <button class="btn btn-accent" onclick="saveSocial('tiktok')"><i class="fa-solid fa-floppy-disk"></i> Salva
        canale</button>
      <div id="tiktokStatus" style="margin-top:12px;font-size:0.85rem;display:none;"></div>

      <!-- Credenziali TikTok per-server (AVANZATO / OPZIONALE) -->
      <div style="margin-top:24px;border-top:1px solid var(--border);padding-top:16px;">
        <button type="button"
          style="background:none;border:none;cursor:pointer;width:100%;display:flex;align-items:center;justify-content:space-between;color:var(--muted);padding:0;"
          onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none';this.querySelector('.adv-arrow').style.transform=this.nextElementSibling.style.display==='none'?'rotate(0deg)':'rotate(90deg)'">
          <span style="font-size:0.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;">
            ⚙️ Avanzato — Cookie TikTok del server
            <% if(config.tiktokSession && config.tiktokSession.sessionid){ %>
              <span style="margin-left:8px;font-size:0.72rem;background:rgba(63,185,80,.15);color:#3fb950;padding:2px 8px;border-radius:20px;font-weight:600;">✅ Configurato</span>
            <% } %>
          </span>
          <i class="fa-solid fa-chevron-right adv-arrow" style="font-size:0.8rem;transition:transform .2s;"></i>
        </button>
        <div style="display:none;margin-top:14px;">
          <div class="info-box" style="margin-bottom:14px;">
            <i class="fa-solid fa-circle-info" style="margin-right:6px;color:var(--accent);"></i>
            <strong>Non è necessario in condizioni normali.</strong> Il bot usa automaticamente RSS per rilevare i nuovi video senza richiedere alcun account.<br>
            Configura i cookie solo se le notifiche non arrivano da più di 24 ore, oppure se vuoi che il bot usi il tuo account per accedere a profili privati.
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Session ID <span style="color:var(--muted);font-weight:400;">(sessionid)</span></label>
              <input type="password" class="form-input" id="tiktokSessionId"
                placeholder="F12 → Application → Cookies → tiktok.com → sessionid"
                value="<%= (config.tiktokSession && config.tiktokSession.sessionid) ? '••••••••••••••••' : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label">ttwid</label>
              <input type="password" class="form-input" id="tiktokTtwid"
                placeholder="F12 → Application → Cookies → tiktok.com → ttwid"
                value="<%= (config.tiktokSession && config.tiktokSession.ttwid) ? '••••••••••••••••' : '' %>">
            </div>
          </div>
          <div style="display:flex;gap:10px;align-items:center;">
            <button class="btn btn-accent" onclick="saveTikTokSession()"><i class="fa-solid fa-key"></i> Salva cookie</button>
            <% if(config.tiktokSession && config.tiktokSession.sessionid){ %>
              <button class="btn" style="background:rgba(248,81,73,.12);color:var(--red);" onclick="clearTikTokSession()"><i class="fa-solid fa-trash"></i> Rimuovi</button>
            <% } %>
          </div>
          <div id="tiktokSessionStatus" style="margin-top:10px;font-size:0.85rem;display:none;"></div>
        </div>
      </div>

      <!-- Riepilogo ultimi post recuperati -->
      <div style="margin-top:24px;border-top:1px solid var(--border);padding-top:20px;">
