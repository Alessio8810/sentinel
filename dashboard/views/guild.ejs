      <button class="btn btn-accent" onclick="save('tickets')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── REACTION ROLES ── -->
    <div class="card" id="reactionroles">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(253,186,116,.12);color:#fb923c;"><i
            class="fa-solid fa-face-smile"></i></div>
        <div class="card-header-text">
          <h3>Reaction Roles</h3>
          <p>Ruoli assegnati automaticamente tramite reazioni emoji</p>
        </div>
      </div>
      <% const rr=config.reactionRoles || []; %>
        <% if (rr.length===0) { %>
          <div class="list-empty">
            <i class="fa-regular fa-face-smile"></i>
            <p>Nessun reaction role configurato.<br>Usa <code>/reactionrole create</code> su Discord per crearne uno.
            </p>
          </div>
          <% } else { %>
            <% rr.forEach((r, i)=> { %>
              <div class="list-item">
                <div>
                  <div class="list-item-main">Messaggio <code><%= r.messageId %></code></div>
                  <div class="list-item-sub">
                    <%= r.roles ? r.roles.length : 0 %> ruoli collegati — Tipo: <span class="badge badge-blue">
                        <%= r.type || 'normal' %>
                      </span>
                  </div>
                </div>
              </div>
              <% }); %>
                <% } %>
                  <div class="info-box" style="margin-top:16px;">
                    <i class="fa-solid fa-circle-info" style="margin-right:6px;color:var(--accent);"></i>
                    Gestisci i reaction roles con i comandi: <code>/reactionrole create</code> ·
                    <code>/reactionrole add</code> · <code>/reactionrole delete</code>
                  </div>
    </div>

    <!-- ── PERSONALIZZAZIONE BOT ── -->
