        <div class="check-item">
          <input type="checkbox" id="am_filterEmojis" <%=(config.automod && config.automod.filterEmojis) ? 'checked'
            : '' %>>
          <div class="check-item-text">
            <span class="check-label">Limite Emoji</span>
            <span class="check-sub">Limita il numero di emoji per messaggio</span>
          </div>
