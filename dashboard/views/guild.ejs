          config.twitchAlerts.streamers && config.twitchAlerts.streamers.length>0) },
          { id: 'tiktok', brand: true, icon: 'fa-tiktok', color: 'rgba(255,255,255,.07)', iconColor: '#e6edf3', title:
          'TikTok', desc: 'Notifiche per i nuovi video dei creator TikTok', active: !!(config.tiktokAlerts &&
          config.tiktokAlerts.users && config.tiktokAlerts.users.length>0) },
          { id: 'instagram', brand: true, icon: 'fa-instagram', color: 'rgba(225,48,108,.15)', iconColor: '#e1306c',
          title: 'Instagram', desc: 'Notifiche per i nuovi post degli account Instagram', active:
          !!(config.instagramAlerts && config.instagramAlerts.users && config.instagramAlerts.users.length>0) },
          { id: 'customcmds', brand: false, icon: 'fa-terminal', color: 'rgba(52,211,153,.15)', iconColor: '#34d399',
          title: 'Comandi Custom', desc: 'Crea i tuoi comandi slash con risposte personalizzate', active:
          (config.customCommands||[]).length > 0 },
          { id: 'liveschedule', brand: false, icon: 'fa-calendar-days', color: 'rgba(88,101,242,.15)', iconColor: '#5865F2',
          title: 'Programmazione Live', desc: 'Orari settimanali delle live con notifiche DM ai subscriber', active:
          (config.liveSchedule||[]).length > 0 },
          ];
          %>
          <% pluginList.forEach(p=> { %>
            <a href="#<%= p.id %>" class="plugin-card">
              <div class="plugin-card-top">
                <div class="plugin-card-icon" style="background:<%= p.color %>;color:<%= p.iconColor %>;">
                  <i class="fa-<%= p.brand ? 'brands' : 'solid' %> <%= p.icon %>"></i>
                </div>
                <span class="plugin-status <%= p.active ? 'active' : 'inactive' %>">
                  <span class="dot"></span>
                  <%= p.active ? 'Attivo' : 'Inattivo' %>
                </span>
              </div>
              <div class="plugin-card-title">
                <%= p.title %>
              </div>
              <div class="plugin-card-desc">
                <%= p.desc %>
              </div>
              <div class="plugin-card-footer">
                <span class="plugin-config-btn">Configura <i class="fa-solid fa-arrow-right"></i></span>
              </div>
            </a>
            <% }) %>
      </div>
    </div>

    <!-- ── IMPOSTAZIONI GENERALI ── -->
    <div class="card" id="general">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(139,148,158,.12);color:#8b949e;"><i class="fa-solid fa-gear"></i>
        </div>
        <div class="card-header-text">
          <h3>Impostazioni Generali</h3>
          <p>Configurazione base del bot per questo server</p>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Prefisso comandi</label>
          <input class="form-input" type="text" id="prefix" value="<%= config.prefix || '!' %>" maxlength="5"
            style="max-width:120px;">
          <div class="form-hint">Usato per i comandi testuali legacy (es. <code>!ban</code>)</div>
        </div>
      </div>
      <button class="btn btn-accent" onclick="save('general')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── BENVENUTO ── -->
    <div class="card" id="welcome">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(56,189,248,.12);color:#38bdf8;"><i
            class="fa-solid fa-hand-wave"></i></div>
        <div class="card-header-text">
          <h3>Messaggio di Benvenuto</h3>
          <p>Invia un messaggio quando un nuovo membro si unisce al server</p>
        </div>
      </div>
      <div class="toggle-row">
        <div class="toggle-row-text">
          <span class="toggle-row-label">Abilitato</span>
          <span class="toggle-row-sub">Attiva o disattiva i messaggi di benvenuto</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="welcomeEnabled" <%=config.welcomeEnabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Canale benvenuto</label>
          <select class="form-input" id="welcomeChannel">
            <option value="">— Nessuno —</option>
            <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
              <option value="<%= c.id %>" <%=config.welcomeChannel===c.id ? 'selected' : '' %>># <%= c.name %>
              </option>
              <% }) %>
          </select>
          <div class="form-hint">Canale dove verranno inviati i messaggi di benvenuto</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Messaggio</label>
        <textarea class="form-input" id="welcomeMessage"
          rows="3"><%= config.welcomeMessage || 'Benvenuto {user} in {server}! Siete ora {memberCount} membri.' %></textarea>
        <div class="form-hint">Variabili: <code>{user}</code> <code>{server}</code> <code>{memberCount}</code></div>
      </div>
      <button class="btn btn-accent" onclick="save('welcome')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── LIVELLI XP ── -->
    <div class="card" id="levels">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(255,184,0,.12);color:#ffb800;"><i class="fa-solid fa-star"></i>
        </div>
        <div class="card-header-text">
          <h3>Sistema Livelli XP</h3>
          <p>Assegna XP ai messaggi e premia i membri più attivi</p>
        </div>
      </div>
      <div class="toggle-row">
        <div class="toggle-row-text">
          <span class="toggle-row-label">Abilitato</span>
          <span class="toggle-row-sub">Attiva o disattiva il sistema XP</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="levelsEnabled" <%=config.levelsEnabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Canale level-up</label>
          <select class="form-input" id="levelUpChannel">
            <option value="">— Canale corrente —</option>
            <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
              <option value="<%= c.id %>" <%=config.levelUpChannel===c.id ? 'selected' : '' %>># <%= c.name %>
              </option>
              <% }) %>
          </select>
          <div class="form-hint">Lascia su "Canale corrente" per inviare dove scrive l'utente</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Messaggio Level-Up</label>
        <input class="form-input" type="text" id="levelUpMessage"
          value="<%= config.levelUpMessage || '{user} è salito al livello {level}! 🎉' %>">
        <div class="form-hint">Variabili: <code>{user}</code> <code>{level}</code></div>
      </div>
      <button class="btn btn-accent" onclick="save('levels')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── MOD LOG ── -->
    <div class="card" id="moderation">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(248,81,73,.12);color:#f85149;"><i
            class="fa-solid fa-shield-halved"></i></div>
        <div class="card-header-text">
          <h3>Log Moderazione</h3>
          <p>Registro di tutte le azioni di moderazione (ban, kick, mute, warn)</p>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Canale mod-log</label>
          <select class="form-input" id="modLogChannel">
            <option value="">— Nessuno —</option>
            <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
              <option value="<%= c.id %>" <%=config.modLogChannel===c.id ? 'selected' : '' %>># <%= c.name %>
              </option>
              <% }) %>
          </select>
          <div class="form-hint">Tutte le azioni di moderazione (ban, kick, mute, warn) saranno registrate qui</div>
        </div>
      </div>
      <button class="btn btn-accent" onclick="save('moderation')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>

      <!-- Comandi disponibili -->
      <div style="margin-top:28px;padding-top:24px;border-top:1px solid var(--border);">
        <div style="font-size:0.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;">Comandi disponibili</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;">
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <code style="background:rgba(88,101,242,.15);color:#a5b4fc;padding:2px 8px;border-radius:5px;font-size:0.82rem;font-weight:700;">/ban</code>
              <span style="font-size:0.7rem;background:rgba(248,81,73,.12);color:#f85149;padding:2px 7px;border-radius:99px;font-weight:600;">ADMIN</span>
            </div>
            <div style="font-size:0.82rem;color:var(--muted);line-height:1.5;">Banna un utente dal server con motivo opzionale. Il ban viene registrato nel mod-log.</div>
            <div style="margin-top:8px;font-size:0.75rem;color:var(--muted);opacity:.7;">Opzioni: <code style="font-size:0.75rem;">utente</code> · <code style="font-size:0.75rem;">motivo</code></div>
          </div>
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <code style="background:rgba(88,101,242,.15);color:#a5b4fc;padding:2px 8px;border-radius:5px;font-size:0.82rem;font-weight:700;">/kick</code>
              <span style="font-size:0.7rem;background:rgba(248,81,73,.12);color:#f85149;padding:2px 7px;border-radius:99px;font-weight:600;">ADMIN</span>
            </div>
            <div style="font-size:0.82rem;color:var(--muted);line-height:1.5;">Espelle un utente dal server. Può rientrare con un nuovo invito. Loggato nel mod-log.</div>
            <div style="margin-top:8px;font-size:0.75rem;color:var(--muted);opacity:.7;">Opzioni: <code style="font-size:0.75rem;">utente</code> · <code style="font-size:0.75rem;">motivo</code></div>
          </div>
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <code style="background:rgba(88,101,242,.15);color:#a5b4fc;padding:2px 8px;border-radius:5px;font-size:0.82rem;font-weight:700;">/mute</code>
              <span style="font-size:0.7rem;background:rgba(227,179,65,.12);color:#e3b341;padding:2px 7px;border-radius:99px;font-weight:600;">MOD</span>
            </div>
            <div style="font-size:0.82rem;color:var(--muted);line-height:1.5;">Silenzia un utente con timeout Discord per una durata specificata (in minuti).</div>
            <div style="margin-top:8px;font-size:0.75rem;color:var(--muted);opacity:.7;">Opzioni: <code style="font-size:0.75rem;">utente</code> · <code style="font-size:0.75rem;">durata</code> · <code style="font-size:0.75rem;">motivo</code></div>
          </div>
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <code style="background:rgba(88,101,242,.15);color:#a5b4fc;padding:2px 8px;border-radius:5px;font-size:0.82rem;font-weight:700;">/warn</code>
              <span style="font-size:0.7rem;background:rgba(227,179,65,.12);color:#e3b341;padding:2px 7px;border-radius:99px;font-weight:600;">MOD</span>
            </div>
            <div style="font-size:0.82rem;color:var(--muted);line-height:1.5;">Assegna un avvertimento a un utente con motivo. Accumulabili e consultabili.</div>
            <div style="margin-top:8px;font-size:0.75rem;color:var(--muted);opacity:.7;">Opzioni: <code style="font-size:0.75rem;">utente</code> · <code style="font-size:0.75rem;">motivo</code></div>
          </div>
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <code style="background:rgba(88,101,242,.15);color:#a5b4fc;padding:2px 8px;border-radius:5px;font-size:0.82rem;font-weight:700;">/warnings</code>
              <span style="font-size:0.7rem;background:rgba(139,148,158,.1);color:var(--muted);padding:2px 7px;border-radius:99px;font-weight:600;">TUTTI</span>
            </div>
            <div style="font-size:0.82rem;color:var(--muted);line-height:1.5;">Visualizza tutti gli avvertimenti accumulati da un utente nel server.</div>
            <div style="margin-top:8px;font-size:0.75rem;color:var(--muted);opacity:.7;">Opzioni: <code style="font-size:0.75rem;">utente</code></div>
          </div>
          <div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <code style="background:rgba(88,101,242,.15);color:#a5b4fc;padding:2px 8px;border-radius:5px;font-size:0.82rem;font-weight:700;">/purge</code>
              <span style="font-size:0.7rem;background:rgba(227,179,65,.12);color:#e3b341;padding:2px 7px;border-radius:99px;font-weight:600;">MOD</span>
            </div>
            <div style="font-size:0.82rem;color:var(--muted);line-height:1.5;">Elimina in blocco da 1 a 100 messaggi dal canale corrente. Filtrabile per utente.</div>
            <div style="margin-top:8px;font-size:0.75rem;color:var(--muted);opacity:.7;">Opzioni: <code style="font-size:0.75rem;">quantità</code> · <code style="font-size:0.75rem;">utente</code> (opz.)</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── AUTO-MOD ── -->
    <div class="card" id="automod">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(88,101,242,.12);color:#5865F2;"><i class="fa-solid fa-robot"></i>
        </div>
        <div class="card-header-text">
          <h3>Auto-Mod</h3>
          <p>Filtri automatici per mantenere il server pulito</p>
        </div>
      </div>
      <div class="toggle-row">
        <div class="toggle-row-text">
          <span class="toggle-row-label">Auto-Mod Abilitato</span>
          <span class="toggle-row-sub">Attiva o disattiva tutti i filtri automatici</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="am_enabled" <%=(config.automod && config.automod.enabled) ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>

      <div class="check-grid">
        <div class="check-item">
          <input type="checkbox" id="am_filterLinks" <%=(config.automod && config.automod.filterLinks) ? 'checked' : ''
            %>>
          <div class="check-item-text">
            <span class="check-label">Filtro Link</span>
            <span class="check-sub">Elimina messaggi contenenti URL</span>
          </div>
        </div>
        <div class="check-item">
          <input type="checkbox" id="am_filterInvites" <%=(config.automod && config.automod.filterInvites) ? 'checked'
            : '' %>>
          <div class="check-item-text">
            <span class="check-label">Filtro Inviti Discord</span>
            <span class="check-sub">Blocca link discord.gg</span>
          </div>
        </div>
        <div class="check-item">
          <input type="checkbox" id="am_filterSpam" <%=(config.automod && config.automod.filterSpam) ? 'checked' : ''
            %>>
          <div class="check-item-text">
            <span class="check-label">Anti-Spam</span>
            <span class="check-sub">Limita messaggi rapidi consecutivi</span>
          </div>
        </div>
        <div class="check-item">
          <input type="checkbox" id="am_filterEmojis" <%=(config.automod && config.automod.filterEmojis) ? 'checked'
            : '' %>>
          <div class="check-item-text">
            <span class="check-label">Limite Emoji</span>
            <span class="check-sub">Limita il numero di emoji per messaggio</span>
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Soglia spam (messaggi)</label>
          <input class="form-input" type="number" id="am_spamThreshold"
            value="<%= (config.automod && config.automod.spamThreshold) || 5 %>" min="2" max="20">
          <div class="form-hint">Numero di messaggi prima del mute</div>
        </div>
        <div class="form-group">
          <label class="form-label">Intervallo spam (secondi)</label>
          <input class="form-input" type="number" id="am_spamInterval"
            value="<%= (config.automod && config.automod.spamInterval) ? config.automod.spamInterval / 1000 : 5 %>"
            min="1" max="30">
          <div class="form-hint">Finestra temporale per rilevare lo spam</div>
        </div>
        <div class="form-group">
          <label class="form-label">Limite emoji per messaggio</label>
          <input class="form-input" type="number" id="am_emojiLimit"
            value="<%= (config.automod && config.automod.emojiLimit) || 10 %>" min="1" max="50">
        </div>
        <div class="form-group">
          <label class="form-label">Canale log auto-mod</label>
          <select class="form-input" id="am_logChannel">
            <option value="">— Nessuno —</option>
            <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
              <option value="<%= c.id %>" <%=(config.automod && config.automod.logChannel===c.id) ? 'selected' : '' %>>#
                <%= c.name %>
              </option>
              <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Parole Bannate</label>
        <div class="tag-input-wrap" id="badWordsWrap" onclick="document.getElementById('badWordInput').focus()">
          <% (config.automod && config.automod.badWords || []).forEach(w=> { %>
            <span class="tag" data-word="<%= w %>">
              <%= w %><span class="tag-remove" onclick="removeTag(this)">✕</span>
            </span>
            <% }); %>
              <input class="tag-ghost" id="badWordInput" placeholder="Scrivi e premi Invio...">
        </div>
        <div class="form-hint">Premi Invio o virgola per aggiungere una parola</div>
      </div>

      <button class="btn btn-accent" onclick="save('automod')"><i class="fa-solid fa-floppy-disk"></i> Salva
        Auto-Mod</button>
    </div>

    <!-- ── MUSICA ── -->
    <div class="card" id="music">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(63,185,80,.12);color:#3fb950;"><i class="fa-solid fa-music"></i>
        </div>
        <div class="card-header-text">
          <h3>Musica</h3>
          <p>Canale dedicato e ruolo DJ per i comandi musicali</p>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Canale musica</label>
          <select class="form-input" id="musicChannel">
            <option value="">— Tutti i canali —</option>
            <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
              <option value="<%= c.id %>" <%=config.musicChannel===c.id ? 'selected' : '' %>># <%= c.name %>
              </option>
              <% }) %>
          </select>
          <div class="form-hint">Il bot risponderà ai comandi musicali solo in questo canale</div>
        </div>
        <div class="form-group">
          <label class="form-label">Ruolo DJ</label>
          <select class="form-input" id="djRole">
            <option value="">— Nessuno —</option>
            <% roles.filter(r=> r.name !== '@everyone').forEach(r => { %>
              <option value="<%= r.id %>" <%=config.djRole===r.id ? 'selected' : '' %>>@ <%= r.name %>
              </option>
              <% }) %>
          </select>
          <div class="form-hint">Solo chi ha questo ruolo potrà usare skip/stop/volume</div>
        </div>
      </div>
      <button class="btn btn-accent" onclick="save('music')"><i class="fa-solid fa-floppy-disk"></i> Salva</button>
    </div>

    <!-- ── TICKET ── -->
    <div class="card" id="tickets">
      <div class="card-header">
        <div class="card-icon" style="background:rgba(167,139,250,.12);color:#a78bfa;"><i
            class="fa-solid fa-ticket"></i></div>
        <div class="card-header-text">
          <h3>Sistema Ticket</h3>
          <p>Canali di supporto privati creati dagli utenti</p>
        </div>
      </div>
      <div class="toggle-row">
        <div class="toggle-row-text">
          <span class="toggle-row-label">Ticket Abilitati</span>
          <span class="toggle-row-sub">Permetti agli utenti di aprire ticket di supporto</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="ticketsEnabled" <%=config.ticketsEnabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Categoria ticket</label>
          <select class="form-input" id="ticketCategory">
            <option value="">— Nessuna —</option>
            <% channels.filter(c=> c.type === 4).forEach(c => { %>
              <option value="<%= c.id %>" <%=config.ticketCategory===c.id ? 'selected' : '' %>>📂 <%= c.name %>
              </option>
              <% }) %>
          </select>
          <div class="form-hint">I canali ticket verranno creati dentro questa categoria</div>
        </div>
        <div class="form-group">
          <label class="form-label">Canale log ticket</label>
          <select class="form-input" id="ticketLogChannel">
            <option value="">— Nessuno —</option>
            <% channels.filter(c=> c.type === 0 || c.type === 5).forEach(c => { %>
              <option value="<%= c.id %>" <%=config.ticketLogChannel===c.id ? 'selected' : '' %>># <%= c.name %>
              </option>
