            value="<%= (config.automod && config.automod.spamThreshold) || 5 %>" min="2" max="20">
          <div class="form-hint">Numero di messaggi prima del mute</div>
        </div>
        <div class="form-group">
          <label class="form-label">Intervallo spam (secondi)</label>
          <input class="form-input" type="number" id="am_spamInterval"
            value="<%= (config.automod && config.automod.spamInterval) ? config.automod.spamInterval / 1000 : 5 %>"
            min="1" max="30">
          <div class="form-hint">Finestra temporale per rilevare lo spam</div>
        </div>
        <div class="form-group">
          <label class="form-label">Limite emoji per messaggio</label>
          <input class="form-input" type="number" id="am_emojiLimit"
            value="<%= (config.automod && config.automod.emojiLimit) || 10 %>" min="1" max="50">
        </div>
        <div class="form-group">
          <label class="form-label">ID Canale Log Auto-Mod</label>
          <input class="form-input" type="text" id="am_logChannel"
            value="<%= (config.automod && config.automod.logChannel) || '' %>" placeholder="Es. 123456789012345678">
        </div>
