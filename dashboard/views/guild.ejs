          <label class="form-label">Nickname del bot (su questo server)</label>
          <input class="form-input" type="text" id="botNick" placeholder="Es. ModBot, MusicBot…" maxlength="32">
          <div class="form-hint">Cambia come appare il nome del bot solo in questo server. Lascia vuoto per resettare al
            nome originale.</div>
        </div>
        <div class="form-group">
          <label class="form-label">Stato attività (globale)</label>
          <div style="display:flex;gap:8px;">
            <select class="form-input" id="botActivityType" style="width:150px;flex-shrink:0;">
              <option value="Playing">🎮 Playing</option>
              <option value="Listening">🎧 Listening</option>
              <option value="Watching">👁️ Watching</option>
              <option value="Competing">🏆 Competing</option>
            </select>
            <input class="form-input" type="text" id="botActivityText"
              placeholder="Es. su <%= guild.memberCount %> server…" maxlength="128">
